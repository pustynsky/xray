/target
*.ps1
!e2e-test.ps1
!scripts/*.ps1
todo*.md
proptest-regressions/

# Index files (safety net — should never be created in repo)
*.file-list
*.word-search
*.code-structure
*.file-list.meta
*.word-search.meta
*.code-structure.meta
*.debug.log
# Git history cache
*.git-history
*.git-history.meta
# Legacy extensions (pre-rename, kept for safety)
*.idx
*.cidx
*.didx

# scripts/roslyn-callers-audit blobs (1.7GB Roslyn cross-validation artefacts — BLOB-001)
scripts/roslyn-callers-audit/*.json
scripts/roslyn-callers-audit/cache_*
scripts/roslyn-callers-audit/*_stdout.json
scripts/roslyn-callers-audit/*_stderr.txt

# Script-local logs / output artefacts (PS-010)
scripts/*.log
scripts/*.log.err
scripts/*_output.*
scripts/single_test_output.txt
scripts/line_regex_test_output.txt

# Workspace-root debug artefacts
test-out.log
.vscode/settings.json

# Project-specific content (may contain internal names/links)
user-stories/

# Temp artifacts
docs/pr-description.md
