/target
*.ps1
# Copilot pre-tool-use hook script; must remain tracked despite the ps1 ignore.
!.github/hooks/block-rustfmt.ps1
!e2e-test.ps1
!scripts/setup-xray.ps1
# MCP-filter regression suite that ships with setup-xray.ps1; tracked.
!scripts/mcp-filter/test-roundtrip.ps1
!scripts/mcp-filter/test-e2e.ps1
!scripts/mcp-filter/test-plain-uninstall.ps1
!scripts/mcp-filter/test-worktree.ps1
!scripts/mcp-filter/test-vscode-tracked.ps1
!scripts/mcp-filter/test-install-from-worktree.ps1
# Standalone-install regression suite: stages setup-xray.ps1 with no
# mcp-filter sibling and asserts the embedded fallback + PS 5.1 quoting
# fix both behave correctly. Mutation-killing for both fixes.
!scripts/mcp-filter/test-standalone-install.ps1
# Embedded-vs-disk byte-equality guard for the MCP filter scripts
# (smudge.sh / clean.sh) embedded inside setup-xray.ps1.
!scripts/mcp-filter/test-embedded-sync.ps1
# Get-DetectedExtensions regression suite (mutation guard for setup-xray.ps1
# scan rewrite — case-insensitive prune, hidden files, reparse-point skip).
!scripts/test-detect-extensions.ps1
todo*.md
proptest-regressions/

# Index files (safety net — should never be created in repo)
*.file-list
*.word-search
*.code-structure
*.file-list.meta
*.word-search.meta
*.code-structure.meta
*.debug.log
# Git history cache
*.git-history
*.git-history.meta
# Legacy extensions (pre-rename, kept for safety)
*.idx
*.cidx
*.didx

# scripts/roslyn-callers-audit blobs (1.7GB Roslyn cross-validation artefacts — BLOB-001)
scripts/roslyn-callers-audit/*.json
scripts/roslyn-callers-audit/cache_*
scripts/roslyn-callers-audit/*_stdout.json
scripts/roslyn-callers-audit/*_stderr.txt

# Script-local logs / output artefacts (PS-010)
scripts/*.log
scripts/*.log.err
scripts/*_output.*
scripts/single_test_output.txt
scripts/line_regex_test_output.txt

# Workspace-root debug artefacts
test-out.log
.vscode/settings.json
.vscode/mcp.json

# Project-specific content (may contain internal names/links)
user-stories/
/demo/

# Temp artifacts
docs/pr-description.md

# Workspace-root scratch / debug artefacts (cleanup 2026-05-20)
*.log
test_out*.txt
test_output.txt
check-*.txt

